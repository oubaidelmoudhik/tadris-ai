# ============================================
# Production Environment Variables
# Copy this to .env and fill in the values
# ============================================

# Django Secret Key - Generate a strong random key
# Run: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-secret-key-here

# Database Configuration
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://raida_user:your-secure-password@postgres:5432/raida

# PostgreSQL Password (for docker-compose)
POSTGRES_PASSWORD=your-secure-postgres-password

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# Teacher Subject (French, Arabic, Math)
TEACHER_SUBJECT=French

# Debug Mode (False for production)
DEBUG=False

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=False

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,frontend

# Next.js API URL
NEXT_PUBLIC_API_URL=http://backend:8000
